*.log
logs/

# Local data — raw downloads are huge (3+ GB), never commit
data/raw/
data/local/

# SQLite — commit the small built DB so clones work out of the box,
# but ignore other databases (e.g. local scratch / backups)
*.db
*.sqlite
!data/counties.sqlite
!data/counties.sqlite.example

# QA + test artifacts
app/qa-screenshots/
app/test-results/
app/playwright-report/
app/.playwright/

# Documentation Open-Meteo failures, internal notes etc.
.scratch/
